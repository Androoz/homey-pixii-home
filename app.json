        "id": "balance_grid_power",
        "title": {
          "en": "Balance grid power [[grid_power]] W toward [[target]] W using [[mode]]",
          "sv": "Balansera näteffekt [[grid_power]] W mot [[target]] W med [[mode]]"
        },
        "titleFormatted": {
          "en": "Balance grid power [[grid_power]] W toward [[target]] W using [[mode]]",
          "sv": "Balansera näteffekt [[grid_power]] W mot [[target]] W med [[mode]]"
        },
        "hint": {
          "en": "Recommended for dynamic control. Use the Grid power Flow tag and trigger on every update. A small positive target such as 100 W reduces oscillation and unintended export. Choose bidirectional, charge only, or discharge only according to your energy policy.",
          "sv": "Rekommenderas för dynamisk styrning. Använd Flow-taggen Näteffekt och trigga vid varje uppdatering. Ett litet positivt mål, exempelvis 100 W, minskar pendling och oavsiktlig export. Välj dubbelriktad, endast laddning eller endast urladdning efter din energipolicy."
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=pixii-home"
          },
          {
            "name": "grid_power",
            "type": "number",
            "title": {
              "en": "Current grid power (W)",
              "sv": "Aktuell näteffekt (W)"
            }
          },
          {
            "name": "target",
            "type": "number",
